# Copy this file to `.env` and fill in your Supabase credentials.
# .env is gitignored — never commit it.

# Project URL from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# anon key — safe to expose in browser code
SUPABASE_ANON_KEY=

# service_role key — SECRET. Bypasses Row Level Security.
# Used only by scripts/migrate_to_supabase.py. Never put in client code.
SUPABASE_SERVICE_KEY=

# Postgres direct connection — needed for fast bulk load.
# Dashboard → Project Settings → Database → "Connection string" → URI
# Example: postgresql://postgres.PROJECTREF:YOUR-DB-PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=
